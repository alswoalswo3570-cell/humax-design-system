{
  "typography": {
    "fontFamily": {
      "primary": "Archivo",
      "fallback": "Noto Sans",
      "css": "'Archivo', 'Noto Sans', system-ui, -apple-system, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, monospace",
      "note": "Archivo for English/numbers, Noto Sans for Korean and special symbols (e.g. &)"
    },
    "fontSize": {
      "2xs": "10px",
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "28px",
      "4xl": "32px"
    },
    "fontWeight": {
      "regular": "400",
      "medium": "500",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.4",
      "relaxed": "1.5"
    },
    "textStyle": {
      "headlineLarge":  { "fontSize": "32px", "lineHeight": "40px", "fontWeight": "700" },
      "headlineMedium": { "fontSize": "28px", "lineHeight": "36px", "fontWeight": "700" },
      "headlineSmall":  { "fontSize": "24px", "lineHeight": "32px", "fontWeight": "700" },
      "titleLarge":     { "fontSize": "20px", "lineHeight": "28px", "fontWeight": "700" },
      "titleMedium":    { "fontSize": "18px", "lineHeight": "26px", "fontWeight": "700" },
      "titleSmall":     { "fontSize": "16px", "lineHeight": "24px", "fontWeight": "700" },
      "titlePoint":     { "fontSize": "16px", "lineHeight": "24px", "fontWeight": "500" },
      "bodyTitle":      { "fontSize": "14px", "lineHeight": "18px", "fontWeight": "700" },
      "bodyPoint":      { "fontSize": "14px", "lineHeight": "18px", "fontWeight": "500" },
      "bodyCommon":     { "fontSize": "14px", "lineHeight": "18px", "fontWeight": "400" },
      "captionTitle":   { "fontSize": "12px", "lineHeight": "16px", "fontWeight": "700" },
      "captionPoint":   { "fontSize": "12px", "lineHeight": "16px", "fontWeight": "500" },
      "captionPointUnderline": { "fontSize": "12px", "lineHeight": "16px", "fontWeight": "400", "textDecoration": "underline" },
      "captionCommon":  { "fontSize": "12px", "lineHeight": "16px", "fontWeight": "400" },
      "captionMiniPoint": { "fontSize": "10px", "lineHeight": "14px", "fontWeight": "500" }
    }
  },
  "space": {
    "none": "0px",
    "xxs": "4px",
    "xs":  "8px",
    "s":   "12px",
    "m":   "16px",
    "l":   "20px",
    "xl":  "24px",
    "xxl": "32px"
  },
  "breakpoint": {
    "compact":  "0px",
    "medium":   "600px",
    "expanded": "840px"
  },
  "grid": {
    "compact":  { "margin": "20px", "gutter": "8px",  "columns": 4 },
    "medium":   { "margin": "24px", "gutter": "16px", "columns": 8 },
    "expanded": { "margin": "32px", "gutter": "24px", "columns": 12 }
  },
  "radius": {
    "none": "0px",
    "sm": "0.125rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "full": "9999px"
  },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.06)"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-out": "cubic-bezier(0.0, 0, 0.2, 1)",
      "ease-in": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "focusRing": {
    "thickness": "2px",
    "offset": "2px"
  }
}
